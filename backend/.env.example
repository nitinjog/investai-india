# ─── Required ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional ────────────────────────────────────────────────
DATAGOV_API_KEY=your_datagov_key_here   # data.gov.in (free)

# ─── App config ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
CACHE_TTL_PRICES=900        # 15 min
CACHE_TTL_FD=86400          # 24 hr
CACHE_TTL_MACRO=86400       # 24 hr
CACHE_TTL_NEWS=1800         # 30 min
CACHE_TTL_GOLD=1800         # 30 min

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.netlify.app
